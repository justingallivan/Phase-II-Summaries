{
  "name": "wmkf_app_publication",
  "kind": "new-entity",
  "schemaName": "wmkf_AppPublication",
  "displayName": "App Publication",
  "displayCollectionName": "App Publications",
  "description": "Publications surfaced by the Reviewer Finder bibliometric searches. Authorship is its own junction (wmkf_app_publication_author) — no researcher FK on this row.",
  "ownershipType": "OrganizationOwned",
  "primaryNameAttribute": {
    "schemaName": "wmkf_Title",
    "displayName": "Title",
    "description": "Publication title. Primary name attribute (Memo because long titles overflow single-line).",
    "maxLength": 4000,
    "requiredLevel": "ApplicationRequired"
  },
  "attributes": [
    {
      "type": "Memo",
      "schemaName": "wmkf_AuthorsRaw",
      "displayName": "Authors (Raw)",
      "description": "Full authors[] joined as text. Preserves the original list for display; the junction only tracks researchers we know about.",
      "maxLength": 20000
    },
    {
      "type": "String",
      "schemaName": "wmkf_Journal",
      "displayName": "Journal",
      "maxLength": 500
    },
    {
      "type": "String",
      "schemaName": "wmkf_Doi",
      "displayName": "DOI",
      "description": "Digital Object Identifier. Alternate key.",
      "maxLength": 100
    },
    {
      "type": "String",
      "schemaName": "wmkf_Pmid",
      "displayName": "PMID",
      "maxLength": 50
    },
    {
      "type": "String",
      "schemaName": "wmkf_Pmcid",
      "displayName": "PMCID",
      "maxLength": 50
    },
    {
      "type": "String",
      "schemaName": "wmkf_ArxivId",
      "displayName": "arXiv ID",
      "maxLength": 100
    },
    {
      "type": "DateTime",
      "schemaName": "wmkf_PublicationDate",
      "displayName": "Publication Date",
      "format": "DateOnly",
      "behavior": "DateOnly"
    },
    {
      "type": "Integer",
      "schemaName": "wmkf_Year",
      "displayName": "Year",
      "minValue": 1900,
      "maxValue": 2200
    },
    {
      "type": "Integer",
      "schemaName": "wmkf_Citations",
      "displayName": "Citations",
      "minValue": 0,
      "maxValue": 1000000
    },
    {
      "type": "Memo",
      "schemaName": "wmkf_Abstract",
      "displayName": "Abstract",
      "maxLength": 100000
    },
    {
      "type": "String",
      "schemaName": "wmkf_Source",
      "displayName": "Source",
      "description": "Origin of the record (pubmed, arxiv, biorxiv, chemrxiv, etc.).",
      "maxLength": 50
    },
    {
      "type": "String",
      "schemaName": "wmkf_Url",
      "displayName": "URL",
      "format": "Url",
      "maxLength": 500
    }
  ],
  "relationships": [],
  "alternateKeys": [
    {
      "schemaName": "wmkf_doi",
      "displayName": "DOI",
      "keyAttributes": ["wmkf_doi"]
    }
  ]
}
