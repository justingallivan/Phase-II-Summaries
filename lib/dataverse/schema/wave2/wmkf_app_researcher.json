{
  "name": "wmkf_app_researcher",
  "kind": "new-entity",
  "schemaName": "wmkf_AppResearcher",
  "displayName": "App Researcher",
  "displayCollectionName": "App Researchers",
  "description": "Bibliometric/contact records for external researchers surfaced by the Reviewer Finder. Optional lookup to a foundation contact when promoted.",
  "ownershipType": "OrganizationOwned",
  "primaryNameAttribute": {
    "schemaName": "wmkf_Name",
    "displayName": "Name",
    "description": "Researcher's display name. Primary name attribute.",
    "maxLength": 255,
    "requiredLevel": "ApplicationRequired"
  },
  "attributes": [
    {
      "type": "String",
      "schemaName": "wmkf_NormalizedName",
      "displayName": "Normalized Name",
      "description": "Lowercase / diacritic-stripped name for dedupe lookups.",
      "maxLength": 255
    },
    {
      "type": "String",
      "schemaName": "wmkf_PrimaryAffiliation",
      "displayName": "Primary Affiliation",
      "maxLength": 500
    },
    {
      "type": "String",
      "schemaName": "wmkf_Department",
      "displayName": "Department",
      "maxLength": 255
    },
    {
      "type": "String",
      "schemaName": "wmkf_Email",
      "displayName": "Email",
      "format": "Email",
      "maxLength": 255
    },
    {
      "type": "String",
      "schemaName": "wmkf_Orcid",
      "displayName": "ORCID",
      "description": "ORCID identifier (xxxx-xxxx-xxxx-xxxx). Alternate key.",
      "maxLength": 50
    },
    {
      "type": "String",
      "schemaName": "wmkf_GoogleScholarId",
      "displayName": "Google Scholar ID",
      "maxLength": 100
    },
    {
      "type": "String",
      "schemaName": "wmkf_GoogleScholarUrl",
      "displayName": "Google Scholar URL",
      "format": "Url",
      "maxLength": 500
    },
    {
      "type": "String",
      "schemaName": "wmkf_OrcidUrl",
      "displayName": "ORCID URL",
      "format": "Url",
      "maxLength": 255
    },
    {
      "type": "Integer",
      "schemaName": "wmkf_HIndex",
      "displayName": "H-Index",
      "minValue": 0,
      "maxValue": 1000
    },
    {
      "type": "Integer",
      "schemaName": "wmkf_I10Index",
      "displayName": "i10-Index",
      "minValue": 0,
      "maxValue": 100000
    },
    {
      "type": "Integer",
      "schemaName": "wmkf_TotalCitations",
      "displayName": "Total Citations",
      "minValue": 0,
      "maxValue": 100000000
    },
    {
      "type": "String",
      "schemaName": "wmkf_FacultyPageUrl",
      "displayName": "Faculty Page URL",
      "format": "Url",
      "maxLength": 500
    },
    {
      "type": "String",
      "schemaName": "wmkf_Website",
      "displayName": "Website",
      "format": "Url",
      "maxLength": 500
    },
    {
      "type": "Memo",
      "schemaName": "wmkf_Notes",
      "displayName": "Notes",
      "description": "Conflicts, preferences, free-form notes.",
      "maxLength": 100000
    },
    {
      "type": "Memo",
      "schemaName": "wmkf_Keywords",
      "displayName": "Keywords",
      "description": "Topic keywords merged from researcher_keywords (comma- or space-separated).",
      "maxLength": 50000
    },
    {
      "type": "DateTime",
      "schemaName": "wmkf_MetricsUpdatedAt",
      "displayName": "Metrics Updated At",
      "description": "Last refresh of citation metrics."
    },
    {
      "type": "DateTime",
      "schemaName": "wmkf_LastChecked",
      "displayName": "Last Checked",
      "description": "Last time the row was reviewed/refreshed."
    },
    {
      "type": "DateTime",
      "schemaName": "wmkf_ContactEnrichedAt",
      "displayName": "Contact Enriched At",
      "description": "Last time the researcher's contact info was enriched."
    },
    {
      "type": "String",
      "schemaName": "wmkf_EmailSource",
      "displayName": "Email Source",
      "description": "Where the email came from (orcid, scholar, manual, etc.).",
      "maxLength": 100
    },
    {
      "type": "String",
      "schemaName": "wmkf_ContactEnrichmentSource",
      "displayName": "Contact Enrichment Source",
      "maxLength": 100
    }
  ],
  "relationships": [
    {
      "kind": "N:1",
      "schemaName": "wmkf_appresearcher_contact",
      "referencedEntity": "contact",
      "lookupSchemaName": "wmkf_Contact",
      "lookupDisplayName": "Foundation Contact",
      "lookupDescription": "Set when this researcher has been promoted to a foundation contact record.",
      "required": "None"
    }
  ],
  "alternateKeys": [
    {
      "schemaName": "wmkf_orcid",
      "displayName": "ORCID",
      "keyAttributes": ["wmkf_orcid"]
    }
  ]
}
