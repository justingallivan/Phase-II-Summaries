{
  "name": "wmkf_app_publication_author",
  "kind": "new-entity",
  "schemaName": "wmkf_AppPublicationAuthor",
  "displayName": "App Publication Author",
  "displayCollectionName": "App Publication Authors",
  "description": "Junction linking a publication to a researcher we track. Only authors that resolve to a wmkf_app_researcher row appear here; the full author list lives on wmkf_app_publication.wmkf_authorsraw as text.",
  "ownershipType": "OrganizationOwned",
  "primaryNameAttribute": {
    "schemaName": "wmkf_AuthorshipKey",
    "displayName": "Authorship Key",
    "description": "Synthetic primary name (publication GUID + position).",
    "maxLength": 100,
    "requiredLevel": "ApplicationRequired"
  },
  "attributes": [
    {
      "type": "Integer",
      "schemaName": "wmkf_AuthorPosition",
      "displayName": "Author Position",
      "description": "1 = first author, 2 = second, etc.",
      "minValue": 1,
      "maxValue": 1000
    }
  ],
  "relationships": [
    {
      "kind": "N:1",
      "schemaName": "wmkf_apppublicationauthor_publication",
      "referencedEntity": "wmkf_apppublication",
      "lookupSchemaName": "wmkf_Publication",
      "lookupDisplayName": "Publication",
      "lookupDescription": "The publication this authorship belongs to.",
      "required": "ApplicationRequired"
    },
    {
      "kind": "N:1",
      "schemaName": "wmkf_apppublicationauthor_researcher",
      "referencedEntity": "wmkf_appresearcher",
      "lookupSchemaName": "wmkf_Researcher",
      "lookupDisplayName": "Researcher",
      "lookupDescription": "The researcher credited as an author.",
      "required": "ApplicationRequired"
    }
  ],
  "alternateKeys": [
    {
      "schemaName": "wmkf_publication_position",
      "displayName": "Publication + Position",
      "keyAttributes": ["wmkf_publication", "wmkf_authorposition"]
    }
  ]
}
